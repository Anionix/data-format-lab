{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anionix.dev/schemas/diagnostic-triage/v1/finding.schema.json",
  "title": "Diagnostic Triage FindingV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "finding_id",
    "fingerprint",
    "tool",
    "language",
    "severity",
    "category",
    "micro_category",
    "message",
    "expected",
    "observed",
    "verdict",
    "state",
    "evidence_ids",
    "fix"
  ],
  "properties": {
    "schema_version": { "const": "diagnostic-triage.finding/v1" },
    "finding_id": { "type": "string", "format": "uuid" },
    "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "rule_id"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 64 },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "rule_id": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "language": {
      "enum": ["PYTHON", "JAVASCRIPT", "TYPESCRIPT", "RUST", "JSON", "CSS", "GRAPHQL", "UNKNOWN"]
    },
    "severity": { "enum": ["ERROR", "WARNING", "INFO"] },
    "category": {
      "enum": ["syntax", "type", "correctness", "runtime", "build", "test", "resource", "concurrency", "security", "environment", "tooling", "style", "robustness"]
    },
    "micro_category": { "type": "string" },
    "message": { "type": "string", "minLength": 1, "maxLength": 8192 },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "start"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "start": { "$ref": "#/$defs/position" },
        "end": { "$ref": "#/$defs/position" }
      }
    },
    "expected": { "type": "string", "maxLength": 8192 },
    "observed": { "type": "string", "maxLength": 8192 },
    "verdict": { "enum": ["PASS", "POLICY_FAIL", "INCOMPLETE", "UNSUPPORTED"] },
    "state": {
      "enum": ["DISCOVERED", "NORMALIZED", "CLASSIFIED", "FIX_PROPOSED", "VERIFIED", "REPORTED", "INCOMPLETE", "UNSUPPORTED"]
    },
    "evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 64,
      "items": { "type": "string", "format": "uuid" }
    },
    "fix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicability", "tool_native"],
      "properties": {
        "applicability": { "enum": ["SAFE", "UNSAFE", "MANUAL", "NONE"] },
        "tool_native": { "type": "boolean" },
        "patch_evidence_id": { "type": "string", "format": "uuid" }
      },
      "allOf": [
        {
          "if": { "properties": { "applicability": { "const": "NONE" } }, "required": ["applicability"] },
          "then": { "not": { "required": ["patch_evidence_id"] } },
          "else": true
        },
        {
          "if": { "properties": { "applicability": { "enum": ["UNSAFE", "MANUAL"] } }, "required": ["applicability"] },
          "then": { "required": ["patch_evidence_id"] }
        },
        {
          "if": { "properties": { "tool_native": { "const": false } }, "required": ["tool_native"] },
          "then": { "properties": { "applicability": { "enum": ["MANUAL", "NONE"] } } }
        }
      ]
    }
  },
  "allOf": [
    {
      "oneOf": [
        { "properties": { "state": { "const": "INCOMPLETE" }, "verdict": { "const": "INCOMPLETE" } } },
        { "properties": { "state": { "const": "UNSUPPORTED" }, "verdict": { "const": "UNSUPPORTED" } } },
        {
          "properties": {
            "state": { "enum": ["DISCOVERED", "NORMALIZED", "CLASSIFIED", "FIX_PROPOSED", "VERIFIED", "REPORTED"] },
            "verdict": { "enum": ["PASS", "POLICY_FAIL"] }
          }
        }
      ]
    },
    {
      "oneOf": [
        { "properties": { "category": { "const": "syntax" }, "micro_category": { "enum": ["parse-error", "invalid-token", "invalid-structure", "unknown"] } } },
        { "properties": { "category": { "const": "type" }, "micro_category": { "enum": ["incompatible-type", "missing-type", "nullability", "unresolved-symbol", "invalid-call", "contract-mismatch", "unknown"] } } },
        { "properties": { "category": { "const": "correctness" }, "micro_category": { "enum": ["assertion", "invariant", "wrong-result", "data-loss", "state-transition", "nondeterminism", "unknown"] } } },
        { "properties": { "category": { "const": "runtime" }, "micro_category": { "enum": ["exception", "panic", "abort", "signal", "import-failure", "initialization", "unknown"] } } },
        { "properties": { "category": { "const": "build" }, "micro_category": { "enum": ["compile", "link", "dependency-resolution", "code-generation", "configuration", "unknown"] } } },
        { "properties": { "category": { "const": "test" }, "micro_category": { "enum": ["collection", "setup", "assertion", "teardown", "flaky", "coverage-gate", "unknown"] } } },
        { "properties": { "category": { "const": "resource" }, "micro_category": { "enum": ["timeout", "memory-limit", "disk-limit", "output-limit", "file-descriptor-limit", "unknown"] } } },
        { "properties": { "category": { "const": "concurrency" }, "micro_category": { "enum": ["race", "deadlock", "livelock", "ordering", "atomicity", "unknown"] } } },
        { "properties": { "category": { "const": "security" }, "micro_category": { "enum": ["input-validation", "path-escape", "injection", "unsafe-deserialization", "permission", "secret-exposure", "unknown"] } } },
        { "properties": { "category": { "const": "environment" }, "micro_category": { "enum": ["tool-missing", "version-mismatch", "platform", "locale", "timezone", "network", "filesystem", "unknown"] } } },
        { "properties": { "category": { "const": "tooling" }, "micro_category": { "enum": ["protocol", "malformed-output", "provider-crash", "unsupported-version", "configuration", "unknown"] } } },
        { "properties": { "category": { "const": "style" }, "micro_category": { "enum": ["format", "lint", "documentation", "complexity", "deprecation", "unknown"] } } },
        { "properties": { "category": { "const": "robustness" }, "micro_category": { "enum": ["boundary-input", "malformed-input", "crash-resistance", "roundtrip-mismatch", "fuzz-finding", "unknown"] } } }
      ]
    }
  ],
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^(?!/)(?![A-Za-z]:/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\\\u0000]+$"
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "column"],
      "properties": {
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
